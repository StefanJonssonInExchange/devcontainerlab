{
  "name": "DevContainerLab",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "OPENCODE_API_KEY": "${localEnv:OPENCODE_API_KEY}",
    "REPO_URL": "${localEnv:REPO_URL}",
    "OPENCODE_PROMPT": "${localEnv:OPENCODE_PROMPT}"
  },
  "postCreateCommand": "bash .devcontainer/run-fix.sh",
  "remoteUser": "root"
}
